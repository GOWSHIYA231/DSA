#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cout<<"enter n;";
    cin>>n;
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n-i;j++)
        {
        cout<<" ";
        }
        //space
        for(int j=1;j<=2*i-1;j++)
        {
        cout<<"*";
        }
        //star
        cout<<"\n";
    }
    for(int i=n;i>=1;i--)
    {
        for(int j=1;j<=n-i;j++)
        {
        cout<<" ";
        }
        //space
        for(int j=1;j<=2*i-1;j++)
        {
        cout<<"*";
        }
        //star
        cout<<"\n";
    }
     return 0;
}
