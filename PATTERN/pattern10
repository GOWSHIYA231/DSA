#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cout << "Enter n: ";
    cin >> n;
    // Upper half
    for(int i = 1; i <= n; i++)
    {
        // Spaces
        for(int j = 1; j <= n - i; j++)
        {
            cout << " ";
        }

        // Stars
        for(int j = 1; j <= 2 * i - 1; j++)
        {
            cout << "*";
        }

        cout << "\n";
 }

    // Lower half
    for(int i = n - 1; i >= 1; i--)
    {
        // Spaces
        for(int j = 1; j <= n - i; j++)
        {
            cout << " ";
        }

        // Stars
        for(int j = 1; j <= 2 * i - 1; j++)
        {
            cout << "*";
        }

        cout << "\n";
    }

    return 0;
}
